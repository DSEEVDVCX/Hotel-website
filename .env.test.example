# Test environment — copy to .env.test and adjust credentials.
# Integration tests wipe core tables, so this MUST be a separate database
# whose name contains "test" (enforced by tests/setup.ts).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_booking_test?schema=public"
NEXTAUTH_SECRET="test-secret"
NEXTAUTH_URL="http://localhost:3000"
# Firebase is skipped in tests (Postgres is the source of truth). Leave unset.
