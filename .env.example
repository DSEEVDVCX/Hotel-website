# Firebase Realtime Database (Admin SDK) — durable copy of accounts + reviews.
# Provide the service account ONE of two ways:
#   (easy)  FIREBASE_SERVICE_ACCOUNT_PATH — path to the downloaded key .json file
#   (or)    FIREBASE_SERVICE_ACCOUNT      — the whole key JSON on a single line
# Leave all unset to skip Firebase (Postgres stays the source of truth).
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-key.json"
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"..."}'
FIREBASE_DATABASE_URL="https://sewar-alandalus-default-rtdb.firebaseio.com"


